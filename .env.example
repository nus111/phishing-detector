# ═══════════════════════════════════════
# Phishing Detector - Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════

# ── Database ──
POSTGRES_DB=phishing_detector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://postgres:change_me_in_production@db:5432/phishing_detector

# ── Backend ──
SECRET_KEY=change_me_to_a_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Service ──
ML_SERVICE_URL=http://ml-service:8001
MODEL_PATH=/app/models/xlm-roberta-phishing

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]
